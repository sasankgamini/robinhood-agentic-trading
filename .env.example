ROBINHOOD_ACCOUNT_NUMBER=your-agentic-account-number

# Optional SMTP email alerts for local runs.
# Gmail users usually need an app password, not their normal password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-app-password
TRADE_ALERT_EMAIL_TO=your-email@example.com
TRADE_ALERT_EMAIL_FROM=your-email@example.com
